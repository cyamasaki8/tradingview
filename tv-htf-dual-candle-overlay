// ── Drawing State ─────────────────────────────────────────────────────────────
var box[]   bodyArr  = array.new<box>()
var line[]  wickArr  = array.new<line>()
var label[] labelArr = array.new<label>()

clearDrawings() =>
    for b   in bodyArr  : b.delete()
    for w   in wickArr  : w.delete()
    for lbl in labelArr : lbl.delete()
    bodyArr.clear()
    wickArr.clear()
    labelArr.clear()

drawOverlay(float[] oArr, float[] hArr, float[] lArr, float[] cArr,
            int count, int cWidth, int cGap, int cRight,
            color bullCol, color bearCol, color wickCol, bool showLbl) =>
    for i = 0 to count - 1
        float o = oArr.get(i)
        float h = hArr.get(i)
        float l = lArr.get(i)
        float c = cArr.get(i)

        if na(o) or na(h) or na(l) or na(c)
            continue

        float bodyTop = math.max(o, c)
        float bodyBot = math.min(o, c)
        color col     = c >= o ? bullCol : bearCol

        // slot 0 = oldest (leftmost), slot count-1 = current (rightmost)
        int slot   = count - 1 - i
        int xLeft  = bar_index + cRight + slot * (cWidth + cGap)
        int xRight = xLeft + cWidth
        int xMid   = xLeft + int(cWidth / 2)

        bodyArr.push(box.new(xLeft, bodyTop, xRight, bodyBot,
             xloc=xloc.bar_index, bgcolor=col, border_color=col))

        if h > bodyTop
            wickArr.push(line.new(xMid, h, xMid, bodyTop,
                 xloc=xloc.bar_index, color=wickCol, width=1))
        if l < bodyBot
            wickArr.push(line.new(xMid, bodyBot, xMid, l,
                 xloc=xloc.bar_index, color=wickCol, width=1))

        if showLbl
            string txt = i == 0 ? "C" : str.tostring(i)
            labelArr.push(label.new(xMid, h, txt,
                 xloc=xloc.bar_index, yloc=yloc.abovebar,
                 color=color.new(color.white, 100), textcolor=color.gray,
                 size=size.tiny, style=label.style_none))

// ── Render ────────────────────────────────────────────────────────────────────

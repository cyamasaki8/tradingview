                               h1_l5,  h1_l6,  h1_l7,  h1_l8,  h1_l9,
                               h1_l10, h1_l11, h1_l12, h1_l13, h1_l14,
                               h1_l15, h1_l16, h1_l17, h1_l18, h1_l19,
                               h1_l20, h1_l21, h1_l22, h1_l23, h1_l24)
    float[] h1_c = array.from(h1_c0,  h1_c1,  h1_c2,  h1_c3,  h1_c4,
                               h1_c5,  h1_c6,  h1_c7,  h1_c8,  h1_c9,
                               h1_c10, h1_c11, h1_c12, h1_c13, h1_c14,
                               h1_c15, h1_c16, h1_c17, h1_c18, h1_c19,
                               h1_c20, h1_c21, h1_c22, h1_c23, h1_c24)

    float[] h2_o = array.from(h2_o0, h2_o1, h2_o2, h2_o3, h2_o4,
                               h2_o5, h2_o6, h2_o7, h2_o8, h2_o9)
    float[] h2_h = array.from(h2_h0, h2_h1, h2_h2, h2_h3, h2_h4,
                               h2_h5, h2_h6, h2_h7, h2_h8, h2_h9)

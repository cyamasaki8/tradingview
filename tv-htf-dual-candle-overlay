    float[] h2_c = array.from(h2_c0, h2_c1, h2_c2, h2_c3, h2_c4,
                               h2_c5, h2_c6, h2_c7, h2_c8, h2_c9)

    drawOverlay(h1_o, h1_h, h1_l, h1_c,
                htf1Count, htf1Width, htf1Gap, htf1Right,
                htf1Bull, htf1Bear, htf1Wick, htf1Labels)
    drawOverlay(h2_o, h2_h, h2_l, h2_c,
                htf2Count, htf2Width, htf2Gap, htf2Right,
                htf2Bull, htf2Bear, htf2Wick, htf2Labels)

    clearDrawings()

    float[] h1_o = array.from(h1_o0,  h1_o1,  h1_o2,  h1_o3,  h1_o4,
                               h1_o5,  h1_o6,  h1_o7,  h1_o8,  h1_o9,
                               h1_o10, h1_o11, h1_o12, h1_o13, h1_o14,
                               h1_o15, h1_o16, h1_o17, h1_o18, h1_o19,
                               h1_o20, h1_o21, h1_o22, h1_o23, h1_o24)
    float[] h1_h = array.from(h1_h0,  h1_h1,  h1_h2,  h1_h3,  h1_h4,
                               h1_h5,  h1_h6,  h1_h7,  h1_h8,  h1_h9,
                               h1_h10, h1_h11, h1_h12, h1_h13, h1_h14,
                               h1_h15, h1_h16, h1_h17, h1_h18, h1_h19,
                               h1_h20, h1_h21, h1_h22, h1_h23, h1_h24)

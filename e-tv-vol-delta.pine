//
// Bulls vs Bears Δ Volume  — standalone subpanel indicator
//
// Must remain separate from the overlay suite because Pine Script does not
// allow a single indicator to occupy both the main chart pane (overlay=true)
// and a subpanel (overlay=false) simultaneously.
//
// Volume delta approximation method:
//   Each bar's volume is split proportionally based on where close landed
//   within the bar's high-low range.
//     buyFrac  = (close - low) / (high - low)
//     bulls    = volume × buyFrac      ← estimated ask-side volume
//     bears    = volume × (1 - buyFrac)← estimated bid-side volume
//     delta    = bulls - bears
//   When high == low (doji / no range), volume is split 50/50.
//
// This is an approximation — true delta requires tick-level data.
// For ES/NQ futures, it is directionally reliable on 5m+ timeframes.

//@version=6
indicator("Bulls vs Bears Δ Vol [CE]", overlay=false)

// ── Inputs ────────────────────────────────────────────────────────
var string G1 = "── Volume Delta ──"
volAvgPeriod = input.int(20,  "Volume MA Period",  group=G1, minval=1)
lineWidth    = input.int(1,   "MA Line Width",     group=G1, minval=1, maxval=4)
bullCol      = input.color(color.new(color.green, 20), "Bull (Ask) Color", group=G1)
bearCol      = input.color(color.new(color.red,   20), "Bear (Bid) Color", group=G1)
showZero     = input.bool(true, "Show Zero Line",  group=G1)

// ── Delta calculation ─────────────────────────────────────────────
float buyFrac    = high == low ? 0.5 : (close - low) / (high - low)
float bulls      = volume * buyFrac
float bears      = volume * (1.0 - buyFrac)
float delta      = bulls - bears
color deltaColor = delta >= 0 ? bullCol : bearCol

// ── Volume SMA ────────────────────────────────────────────────────
float volSMA = ta.sma(volume, volAvgPeriod)

// ── Plots ─────────────────────────────────────────────────────────
if showZero
    hline(0, "Zero", color=color.new(color.gray, 50))

plot(delta,  "Delta",   color=deltaColor,   style=plot.style_histogram)
plot(volSMA, "Vol SMA", color=color.yellow, linewidth=lineWidth)

// ── Last-bar info table (top-right of subpanel) ───────────────────
var table infoTable = table.new(position.top_right, 2, 3,
     bgcolor      = color.new(color.black, 60),
     border_width = 1,
     border_color = color.new(color.gray, 60))

if barstate.islast
    color dColor = delta >= 0 ? color.green : color.red

    table.cell(infoTable, 0, 0, "Ask",
         text_color=color.white,  text_halign=text.align_left,  text_size=size.small)
    table.cell(infoTable, 1, 0, str.tostring(bulls, "#,###"),
         text_color=color.green,  text_halign=text.align_right, text_size=size.small)

    table.cell(infoTable, 0, 1, "Bid",
         text_color=color.white,  text_halign=text.align_left,  text_size=size.small)
    table.cell(infoTable, 1, 1, str.tostring(bears, "#,###"),
         text_color=color.red,    text_halign=text.align_right, text_size=size.small)

    table.cell(infoTable, 0, 2, "Delta",
         text_color=color.white,  text_halign=text.align_left,  text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(delta, "#,###"),
         text_color=dColor,       text_halign=text.align_right, text_size=size.small)
